{
  "name": "jah-ui",
  "version": "1.0.3",
  "description": "A Vue 3 component library",
  "type": "module",
  "main": "./dist/jah-ui.umd.js",
  "module": "./dist/jah-ui.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/jah-ui.es.js",
      "require": "./dist/jah-ui.umd.js"
    },
    "./style.css": "./dist/jah-ui.css"
  },
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "vue",
    "components",
    "ui",
    "storybook"
  ],
  "author": "",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.0",
    "@storybook/addon-viewport": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/vue3": "^8.6.18",
    "@storybook/vue3-vite": "^8.6.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.10",
    "chart.js": "^4.5.1",
    "happy-dom": "^20.9.0",
    "storybook": "^8.6.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.6",
    "vue": "^3.5.0",
    "vue-chartjs": "^5.3.3",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "chart.js": "^4.5.1",
    "vue": "^3.5.0",
    "vue-chartjs": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
