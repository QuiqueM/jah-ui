{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", ".storybook/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.stories.ts",     // 💡 Ignora historias en TypeScript tradicional
    "src/**/*.stories.js",
    "src/**/*.test.ts"       // De paso, ignoramos archivos de pruebas si tienes
  ]
}
